{
  "manifest_version": 3,
  "name": "Speed Reader",
  "version": "1.0",
  "description": "Read web pages faster, one word at a time.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Start Speed Reader"
  },
  "background": {
    "service_worker": "background.js"
  }
}
